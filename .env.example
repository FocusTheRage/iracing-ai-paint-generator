# Copy to .env and fill in your keys
XAI_API_KEY=xai-your-key-here
# Optional: override vision model for reference-photo analysis (default: grok-4.3)
# XAI_VISION_MODEL=grok-4.3
OPENAI_API_KEY=sk-your-key-here
STABILITY_API_KEY=sk-your-key-here

# Optional Gradio settings (app auto-picks next free port if busy)
GRADIO_SERVER_PORT=7860
GRADIO_PORT=7860
GRADIO_HOST=127.0.0.1
GRADIO_SHARE=false
GRADIO_INBROWSER=false
CLEANUP_PORTS=true